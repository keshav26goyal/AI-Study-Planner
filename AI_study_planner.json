      "parameters": {
        "jsCode": "const planned = Number($json['Planned Hours']);\nconst actual = Number($('Code in JavaScript3').item.json.hours);\nconst type = $('Code in JavaScript3').first().json.type;\n\nlet action = \"\";\nlet remark = \"\";\n\nif (type === \"completed\") {\n  action = \"complete\";\n  remark = \"Marked as completed by user\";\n}\n\nelse if (type === \"progress\") {\n  \n  if (actual >= planned) {\n    action = \"complete\";\n    remark = \"Completed with sufficient hours\";\n  } \n  \n  else {\n    action = \"ask_reason\";\n    remark = \"Studied less than planned\";\n  }\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      planned,\n      actual,\n      action,\n      remark\n    }\n  }\n];"
      },
